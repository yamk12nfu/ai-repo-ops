{
  "name": "@ai-repo-ops/aro-cli",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "aro CLI — ai-repo-ops の init / diff / sync / doctor / guard / knowledge コマンド本体。",
  "license": "MIT",
  "main": "dist/main.js",
  "bin": {
    "aro": "bin/aro"
  },
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picomatch": "^4.0.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/picomatch": "^3.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
