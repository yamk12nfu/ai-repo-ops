{
  "name": "ai-repo-ops",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "AI運用基盤の標準装備を複数のGitHubリポジトリへ安全に配布・更新・検証するための中央管理ツール。",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "aro": "node packages/aro-cli/bin/aro",
    "schema:sync": "node scripts/sync-managed-schema.mjs",
    "schema:check": "node scripts/sync-managed-schema.mjs --check",
    "release:check": "node scripts/release-check.mjs"
  }
}
